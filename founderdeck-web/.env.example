# ⚠️ WARNING: VITE_ variables are exposed in the browser bundle — never put secrets here!

# Laravel backend origin. Do not add secrets here. The app will append /api.
VITE_API_URL=http://localhost:8000

# Reverb WebSocket key (must match REVERB_APP_KEY in Laravel .env)
VITE_REVERB_KEY=founderdeck_local_key

# Reverb WebSocket host (must match REVERB_HOST in Laravel .env)
VITE_REVERB_HOST=localhost

# Reverb WebSocket port (must match REVERB_PORT in Laravel .env)
VITE_REVERB_PORT=8080

# Reverb WebSocket scheme (http for local dev)
VITE_REVERB_SCHEME=http
