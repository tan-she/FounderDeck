# --------------------------------------------------------------------------
# 1. App Basics
# --------------------------------------------------------------------------
APP_NAME=FounderDeck
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# --------------------------------------------------------------------------
# 2. Database
# --------------------------------------------------------------------------
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=founderdeck
DB_USERNAME=postgres
DB_PASSWORD=your-local-postgres-password

# --------------------------------------------------------------------------
# 3. Cache / Session / Queue
# --------------------------------------------------------------------------
BROADCAST_CONNECTION=reverb
CACHE_STORE=file
CACHE_PREFIX=
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# --------------------------------------------------------------------------
# 4. Broadcasting / Reverb
# --------------------------------------------------------------------------
REVERB_APP_ID=123456
REVERB_APP_KEY=founderdeck_local_key
REVERB_APP_SECRET=founderdeck_local_secret
REVERB_HOST="localhost"
REVERB_PORT=8080
REVERB_SCHEME=http
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# --------------------------------------------------------------------------
# 5. CORS & Sanctum
# --------------------------------------------------------------------------
FRONTEND_URL=http://localhost:5173
SANCTUM_STATEFUL_DOMAINS=localhost:5173,127.0.0.1:5173

# --------------------------------------------------------------------------
# 6. Google OAuth
# --------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your-google-oauth-client-id-here
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret-here
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# --------------------------------------------------------------------------
# 7. Mail
# --------------------------------------------------------------------------
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@founderdeck.com"
MAIL_FROM_NAME="${APP_NAME}"

# --------------------------------------------------------------------------
# 8. Super Admin Seed Credentials
# --------------------------------------------------------------------------
SUPER_ADMIN_EMAIL=admin@founderdeck.com
SUPER_ADMIN_PASSWORD=password

# --------------------------------------------------------------------------
# 9. Optional Future Keys
# --------------------------------------------------------------------------
# STRIPE_KEY=
# STRIPE_SECRET=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
# AWS_BUCKET=
